{
  "name": "codingmacro",
  "version": "0.1.0",
  "description": "Gamepad control center for Codex, Claude Code, and AI coding agents.",
  "license": "MIT",
  "author": "Yinghao Tang",
  "contributors": [
    "Stephen Leo (OpenMicro upstream)"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MisterBrookT/CodingMacro.git"
  },
  "type": "module",
  "bin": {
    "codingmacro": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./harness": {
      "types": "./dist/harness/index.d.ts",
      "default": "./dist/harness/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "NOTICE.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "allowScripts": {
    "node-pty": true,
    "node-hid": true,
    "esbuild": true
  },
  "scripts": {
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper ../node-pty/prebuilds/*/spawn-helper 2>/dev/null || true",
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "capture": "tsx scripts/capture-hid.ts",
    "gen:controllers": "tsx scripts/gen-controller-table.ts && prettier --write CONTROLLERS.md",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "dualsense-ts": "^6.15.0",
    "node-hid": "^3.3.0",
    "node-pty": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
